CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Security — CHANGE THIS in production
SECRET_KEY=replace-with-a-long-random-string-please

# Optional integrations
OPENAI_API_KEY=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
